{
  "name": "primemix",
  "version": "1.0.0",
  "description": "PrimeMix - Premium Ambient Sound Mixer with System Tray support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node scripts/check.js",
    "build": "electron-builder --windows"
  },
  "keywords": [
    "ambient",
    "sounds",
    "mixer",
    "relax",
    "focus",
    "sleep"
  ],
  "author": {
    "name": "Maximus Prime",
    "email": "b.maximus.prime@gmail.com",
    "url": "https://github.com/MaximusPrime77"
  },
  "homepage": "https://github.com/MaximusPrime77/PrimeMix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaximusPrime77/PrimeMix.git"
  },
  "bugs": {
    "url": "https://github.com/MaximusPrime77/PrimeMix/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.primemix.app",
    "productName": "PrimeMix",
    "copyright": "Copyright © 2026 Maximus Prime Software",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ],
      "icon": "app_icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "tray_icon.png",
      "app_icon.png"
    ],
    "asar": true
  }
}
