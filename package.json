{
  "name": "primemix",
  "version": "1.0.0",
  "description": "PrimeMix - Premium Ambient Sound Mixer with System Tray support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node scripts/check.js",
    "build": "electron-builder --windows"
  },
  "keywords": [
    "ambient",
    "sounds",
    "mixer",
    "relax",
    "focus",
    "sleep"
  ],
  "author": {
    "name": "Maximus Prime",
    "email": "maximusprimesoftware@gmail.com",
    "url": "https://github.com/MaximusPrime"
  },
  "contributors": [
    {
      "name": "Maximus Prime Software",
      "email": "maximusprimesoftware@gmail.com",
      "url": "https://maximusprimesoftware.pages.dev/"
    }
  ],
  "homepage": "https://maximusprimesoftware.pages.dev/projects/primemix/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaximusPrime/PrimeMix.git"
  },
  "bugs": {
    "url": "https://github.com/MaximusPrime/PrimeMix/issues",
    "email": "maximusprimesoftware@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.primemix.app",
    "productName": "PrimeMix",
    "copyright": "Copyright © 2026 Maximus Prime Software",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ],
      "icon": "app_icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "tray_icon.png",
      "app_icon.png"
    ],
    "asar": true
  }
}
